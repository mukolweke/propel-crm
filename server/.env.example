# Server
NODE_ENV=development
PORT=4000

# MongoDB Atlas (free tier)
# 1. Resume or create cluster at https://cloud.mongodb.com → Database → Clusters
# 2. Security → Database Access: create user (e.g. propel_user) — save password
# 3. Security → Network Access → Add IP → "Allow Access from Anywhere" (0.0.0.0/0) for demo
# 4. Clusters → Connect → Drivers → copy connection string, replace <password>, set DB name
# Example (LifeManager cluster): mongodb+srv://propel_user:YOUR_PASSWORD@lifemanager.xxxxx.mongodb.net/propel-crm?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>.mongodb.net/propel-crm?retryWrites=true&w=majority

# JWT — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Vue frontend URL(s), comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Phone normalization default country code (Kenya)
DEFAULT_PHONE_COUNTRY_CODE=254

# Mailtrap (https://mailtrap.io) — password reset emails
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
EMAIL_FROM=noreply@propelcrm.com
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Optional — bootstrap super admin (required for `npm run seed`; never commit real values)
# SEED_ADMIN_EMAIL=admin@your-domain.com
# SEED_ADMIN_PASSWORD=

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# REDIS_URL=redis://localhost:6379
