# Server
NODE_ENV=development
PORT=4000

# MongoDB Atlas
# 1. https://cloud.mongodb.com → Database Access: create a DB user; save password in a secret manager (not git)
# 2. Network Access: add ONLY your deployment egress IP(s) and dev machine IP — do NOT use 0.0.0.0/0 in production
# 3. Clusters → Connect → Drivers → copy URI, replace <password>, set database name (e.g. propel-crm)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>.mongodb.net/propel-crm?retryWrites=true&w=majority

# Optional split credentials (for scripts only — app uses MONGODB_URI above)
DB_USER=propel_user
DB_PASSWORD=changeme
DB_NAME=propel-crm

# JWT — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — Vue frontend URL(s), comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Phone normalization default country code (Kenya)
DEFAULT_PHONE_COUNTRY_CODE=254

# Mailtrap (https://mailtrap.io) — password reset emails
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
EMAIL_FROM=noreply@propelcrm.com
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5

# Optional
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# REDIS_URL=redis://localhost:6379
