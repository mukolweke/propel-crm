{
  "name": "propel-crm-api",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL API for Propel CRM — Real Estate Contact Tracking",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r src/graphql/schema dist/graphql/",
    "start": "node dist/server.js",
    "seed": "tsx scripts/seed.ts",
    "db:reset": "RESET_DB=yes tsx scripts/seed.ts",
    "db:backfill-contacts": "tsx scripts/backfill-contact-normalized.ts",
    "db:check-user": "tsx scripts/check-user.ts",
    "db:migrate": "tsx scripts/migrate-db.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/utils/normalize.test.ts src/modules/contacts/contact-duplicate.service.test.ts src/modules/contacts/contact-search.test.ts src/validators/createUserSchema.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "graphql": "^16.10.0",
    "graphql-depth-limit": "^1.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "nodemailer": "^9.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
